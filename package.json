{
  "name": "table-manager",
  "version": "0.1.0",
  "description": "Desktop poker room coordination system for game formation, waitlists, and occupied seat-hour tracking.",
  "author": "TableManager",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "desktop": "npm run build && node scripts/launch-electron.cjs",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "package:win": "npm run build && electron-builder --win --dir"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  },
  "devDependencies": {
    "electron": "^38.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.tablemanager.desktop",
    "productName": "TableManager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "branding.config.json",
      "package.json"
    ],
    "win": {
      "target": "dir",
      "signAndEditExecutable": false
    }
  }
}
